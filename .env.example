# ERDA data-plane keys — all free tiers. Copy to .env (gitignored) and fill in.
# A missing key makes that source raise SourceUnavailable; nothing is invented.

# EIA Open Data v2 — register: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# FRED — register: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# UN Comtrade (OPTIONAL — keyless preview works but caps at 500 records)
# Register: https://comtradedeveloper.un.org → subscribe to "Free APIs"
COMTRADE_API_KEY=
